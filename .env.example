# ============================================
# LUMEN v1 — Environment
# ============================================

# === LLM ===
OPENROUTER_API_KEY=sk-or-your-key-here

# === Database API Keys ===
NCBI_API_KEY=your-ncbi-key
NCBI_EMAIL=your@email.com
ELSEVIER_API_KEY=your-elsevier-key
ELSEVIER_INST_TOKEN=
WOS_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_EMAIL=your@email.com
UNPAYWALL_EMAIL=your@email.com

# === Database Toggles (true/false) ===
# Set to false to skip during Phase 2
ENABLE_PUBMED=true
ENABLE_EUROPEPMC=true
ENABLE_SCOPUS=true
ENABLE_CROSSREF=true

# === Token Budgets (USD) ===
TOKEN_BUDGET_PHASE1=5.0
TOKEN_BUDGET_PHASE3_TA=10.0
TOKEN_BUDGET_PHASE3_FT=12.0
TOKEN_BUDGET_PHASE4=15.0
TOKEN_BUDGET_PHASE5=5.0
TOKEN_BUDGET_PHASE6=15.0
TOKEN_BUDGET_TOTAL=50.0

# === Langfuse (LLM Observability + TRIPOD-LLM) ===
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# === Pipeline Run Metadata (TRIPOD-LLM Items 7c, 14d) ===
PIPELINE_VERSION=v5
RUN_ID=run_001                  # increment for each new batch run
RUN_DATE=2026-03-12             # update to actual run date (YYYY-MM-DD)
PROSPERO_ID=CRD20XXXXXXXXX      # your PROSPERO registration number
SEED=42                         # global seed for reproducibility (TRIPOD 6c)
